# 登录账号（Docker 部署用；不设则首次打开页面时自行初始化）
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_please
# JWT 签名密钥（不设会自动生成并存库；多容器/重建时建议固定一个随机长串）
# 可用 `openssl rand -hex 32` 生成
JWT_SECRET=

# AI 配置
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=your_key_here
AI_MODEL=glm-4

# 通知配置 - Telegram
NOTIFY_TELEGRAM_BOT_TOKEN=your_bot_token
NOTIFY_TELEGRAM_CHAT_ID=your_chat_id

# 代理配置（国内访问 Telegram 可能需要）
# HTTP_PROXY=http://127.0.0.1:7890

# SSL 企业证书（Zscaler 等企业代理环境需要，留空则不启用）
# CA_CERT_FILE=/path/to/your/enterprise-cert.crt

# 调度配置（cron 表达式：分 时 日 月 周）
DAILY_REPORT_CRON=30 15 * * 1-5

# ============================================================
# Playwright 浏览器配置（K线截图功能）
# ============================================================
# 跳过浏览器安装（不需要截图功能时可设为 1 加快启动）
# PLAYWRIGHT_SKIP_BROWSER_INSTALL=1
# 国内下载加速镜像（Chromium 从默认 CDN 下载很慢时使用）
# PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# ============================================================
# X (Twitter) 舆论监控配置
# ============================================================
# 用于抓取 X 上的股票讨论，建议使用小号
# X_USERNAME=your_twitter_username
# X_EMAIL=your_twitter_email
# X_PASSWORD=your_twitter_password
# 是否启用 AI 情感分析（需要 AI_API_KEY 已配置）
# SOCIAL_SENTIMENT_ENABLED=false